from cla:rp/cla/items/main import OversizedInGuiItemModel

categories = [
    "w_woty",
    "w_innovation",
    "w_aesthetics",
    "w_fun",
    "w_story",
    "w_simulator",
    "w_fighting",
    "w_experimental",
    "w_game_direction",
    "w_music",
    "w_audio_design",
    "w_dp_perf",
    "w_dp_quality",
    "w_rp_textures_models",
    "w_rp_shaders",
    "w_rp_audio",
    "w_build",
    "w_most_anticipated",
    "p_leader",
    "p_solo_dev",
    "p_team",
