class NomineeWorld:
    def __init__(self, world_id, author, icon):
        self.world_id = f".w.{world_id}"
        self.author = author
        self.icon = icon

    def build_item(self, slot, category):
        if (self.icon != "player_head"):
            item replace entity @s f"enderchest.{slot}" with poppy[
                item_model = self.icon, 
                item_name = {translate: self.world_id, font: "cla:ten"}, 
                lore = ["", [{text: f"by {self.author} ", color: "gray"}, {player: self.author, color: "white"}]], 
                tooltip_style = "voting", 
                custom_data = {cla: {ui: 
                { 
                    is_button: true, 
                    no_inventory: true, 
                    button: { 
                        on_click: { 
                            function: "cla:ui/ender_chest/on_click/vote/run", 
                            data: {category: category, nominee: self.world_id}, 
                        } 
                }}}} 
            ]
        else:
            item replace entity @s f"enderchest.{slot}" with poppy[
                item_model = self.icon, 
                profile = self.author,
                tooltip_display = {hidden_components:["profile"]},
                item_name = {translate: self.world_id, font: "cla:ten"}, 
                lore = ["", [{text: f"by {self.author} ", color: "gray"}, {player: self.author, color: "white"}]], 
                tooltip_style = "voting", 
                custom_data = {cla: {ui: 
                { 
                    is_button: true, 
                    no_inventory: true, 
                    button: { 
                        on_click: { 
                            function: "cla:ui/ender_chest/on_click/vote/run", 
                            data: {category: category, nominee: self.world_id}, 
                        } 
                }}}} 
            ]

class NomineeWorldTeam:
    def __init__(self, world_id, team_name, authors, icon):
        self.world_id = f".w.{world_id}"
        self.team_name = team_name
        self.authors = authors
        self.icon = icon

    def build_item(self, slot, category):
        description = ["", [{text: f"by {self.team_name} ", color: "gray"}]]
        for author in self.authors:
            description[1].append({player: author, color: "white"})

        if (self.icon != "player_head"):
            item replace entity @s f"enderchest.{slot}" with poppy[
                item_model = self.icon, 
                item_name = {translate: self.world_id, font: "cla:ten"}, 
                lore = description,
                tooltip_style = "voting", 
                custom_data = {cla: {ui: 
                { 
                    is_button: true, 
                    no_inventory: true, 
                    button: { 
                        on_click: { 
                            function: "cla:ui/ender_chest/on_click/vote/run", 
                            data: {category: category, nominee: self.world_id}, 
                        } 
                }}}} 
            ]
        else:
            item replace entity @s f"enderchest.{slot}" with poppy[
                item_model = self.icon,
                profile = self.authors[0],
                tooltip_display = {hidden_components:["profile"]},
                item_name = {translate: self.world_id, font: "cla:ten"}, 
                lore = description,
                tooltip_style = "voting", 
                custom_data = {cla: {ui: 
                { 
                    is_button: true, 
                    no_inventory: true, 
                    button: { 
                        on_click: { 
                            function: "cla:ui/ender_chest/on_click/vote/run", 
                            data: {category: category, nominee: self.world_id}, 
                        } 
                }}}} 
            ]

class NomineePlayer:
    def __init__(self, player):
        self.name = player
        self.player_id = f".p.{player}".lower()

    def build_item(self, slot, category):
        item replace entity @s f"enderchest.{slot}" with poppy[
            item_model = "player_head",
            profile = self.name,
            tooltip_display = {hidden_components: ["profile"]},
            item_name = [{translate: self.player_id, font: "cla:ten"}, " ", {player: self.name}],
            tooltip_style = "voting", 
            custom_data = {cla: {ui: 
            { 
                is_button: true, 
                no_inventory: true, 
                button: { 
                    on_click: { 
                        function: "cla:ui/ender_chest/on_click/vote/run", 
                        data: {category: category, nominee: self.player_id}, 
                    } 
            }}}} 
        ]

class NomineeTeam:
    def __init__(self, team_id, players, icon):
        self.team_id = f".p.{team_id}".lower()
        self.players = players
        self.icon = icon

    def build_item(self, slot, category):
        title = [{translate: self.team_id, font: "cla:ten"}, " "]
        for player in self.players:
            title.append({"player": player})

        item replace entity @s f"enderchest.{slot}" with poppy[
            item_model = self.icon, 
            item_name = title, 
            tooltip_style = "voting", 
            custom_data = {cla: {ui: 
            { 
                is_button: true, 
                no_inventory: true, 
                button: { 
                    on_click: { 
                        function: "cla:ui/ender_chest/on_click/vote/run", 
                        data: {category: category, nominee: self.team_id}, 
                    } 
            }}}} 
        ]

