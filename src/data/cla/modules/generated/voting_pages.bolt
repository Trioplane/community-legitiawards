# ty chatgpt lmao i was too lazy chat
def get_slot_indices(start, end, count, gap=1):
    slots = []
    step = gap + 1
    total_slots = end - start + 1

    # max possible items with this gap
    max_items = (total_slots + gap) // step
    count = min(count, max_items)

    # compute first slot
    center = (start + end) // 2
    if count % 2 == 1:
        # odd: include center
        slots.append(center)
        for i in range(1, (count // 2) + 1):
            slots.append(center - i * step)
            slots.append(center + i * step)
    else:
        # even: symmetric around center (no center)
        for i in range(count // 2):
            slots.append(center - step // 2 - i * step)
            slots.append(center + step // 2 + i * step)

    return sorted(slots)
#------

for i, category in enumerate(categories):
    function f"cla:generated/voting_pages/{category}":
        scoreboard players set @s cla.ui.ender_chest.current_category i

        bg_slots = get_slot_indices(0, 8, len(categories[category]))
        button_slots = get_slot_indices(9, 17, len(categories[category]))

        for j, nominee in enumerate(categories[category]):
            nominee.build_item(button_slots[j], i)

        # ---------------------------

        for slot in bg_slots:
            item replace entity @s f"enderchest.{slot}" with poppy[\
                item_model = "cla:gui/slot", \
                tooltip_display = {hide_tooltip: true}, \
                custom_data = {cla: {ui: \
                { \
                    is_button: true, \
                    no_inventory: true, \
                }}} \
            ]

        #------------------

        item replace entity @s enderchest.18 with poppy[\
            item_model = "air", \
            tooltip_display = {hide_tooltip: true}, \
            custom_data = {cla: {ui: \
            { \
                is_button: true, \
                no_inventory: true, \
                button: { \
                    on_click: { \
                        function: "cla:ui/ender_chest/on_click/prev_page", \
                    } \
            }}}} \
        ]

        execute if function cla:ui/ender_chest/has_selected_nominee/check run item replace entity @s enderchest.26 with poppy[\
            item_model = "air", \
            tooltip_display = {hide_tooltip: true}, \
            custom_data = {cla: {ui: \
            { \
                is_button: true, \
                no_inventory: true, \
                button: { \
                    on_click: { \
                        function: "cla:ui/ender_chest/on_click/next_page", \
                    } \
            }}}} \
        ]

        execute unless function cla:ui/ender_chest/has_selected_nominee/check run item replace entity @s enderchest.19 with poppy[\
            item_model = "cla:gui/vote", \
            tooltip_display = {hide_tooltip: true}, \
            custom_data = {cla: {ui: \
            { \
                is_button: true, \
                no_inventory: true, \
            }}} \
        ]

        execute if function cla:ui/ender_chest/has_selected_nominee/check run item replace entity @s enderchest.19 with poppy[\
            item_model = "cla:gui/vote_selected", \
            tooltip_display = {hide_tooltip: true}, \
            custom_data = {cla: {ui: \
            { \
                is_button: true, \
                no_inventory: true, \
            }}} \
        ]
        
        item replace entity @s enderchest.21 with poppy[\
            item_model = f"cla:gui/{category}", \
            tooltip_display = {hide_tooltip: true}, \
            custom_data = {cla: {ui: \
            { \
                is_button: true, \
                no_inventory: true, \
            }}} \
        ]

        item replace entity @s enderchest.22 with poppy[\
        item_model = "cla:gui/info", \
        item_name = {translate: f".c.{i}", color: "gray", italic: true},
        custom_data = {cla: {ui: \
        { \
            is_button: true, \
            no_inventory: true, \
        }}} \
    ]

function cla:generated/voting_pages/start:
    item replace entity @s enderchest.4 with poppy[\
        item_model = "cla:gui/vote_button", \
        tooltip_display = {hide_tooltip: true}, \
        custom_data = {cla: {ui: \
        { \
            is_button: true, \
            no_inventory: true, \
        }}} \
    ]
    item replace entity @s enderchest.13 with poppy[\
        item_model = "air", \
        item_name = "Start voting",
        custom_data = {cla: {ui: \
        { \
            is_button: true, \
            no_inventory: true, \
            button: { \
                on_click: { \
                    function: "cla:ui/ender_chest/on_click/next_page", \
                } \
        }}}} \
    ]
    item replace entity @s enderchest.22 with poppy[\
        item_model = "cla:gui/info", \
        item_name = {text: "30 total categories, 44 nominees.", color: "gray", italic: true},
        custom_data = {cla: {ui: \
        { \
            is_button: true, \
            no_inventory: true, \
        }}} \
    ]

